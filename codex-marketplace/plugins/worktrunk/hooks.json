{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'wt config state marker clear >/dev/null 2>&1 || true'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'wt config state marker set 🤖 >/dev/null 2>&1 || true'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'wt config state marker set 💬 >/dev/null 2>&1 || true'"
          }
        ]
      }
    ]
  }
}
